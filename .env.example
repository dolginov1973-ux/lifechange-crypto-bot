# Copy this file to ".env" and fill the SECRETS. The vars are pre-filled for the
# first-partnership test run — swap them for the real partner account later.
# .env is gitignored (never committed). Run:  .\deploy.ps1

# ---- secrets (fill these — values you already have) ----
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
BOT_TOKEN=
BITUNIX_PARTNER_TOKEN=
# optional — leave blank until you provision Crypto Pay (paid path):
CRYPTOPAY_TOKEN=

# ---- vars (pre-filled; change later) ----
OUR_REF_CODE=EJGI
OUR_PARTNER_UID=925331171
MIN_BALANCE_USDT=50
BOT_USERNAME=LifeChange_crypto_bot
REFERRAL_LINK=https://www.bitunix.com/register?vipCode=EJGI
# chat ids — 0 for now; fill the real supergroup/admin ids in Phase 2 (use /id):
VIP_CHAT_ID=0
ADMIN_CHAT_ID=0
# the custom domain attached to the Worker; leave blank for the first deploy,
# attach the domain in the dashboard, set it here, then re-run:
WEBHOOK_DOMAIN=

# auto-generated by the script if blank (don't fill):
WEBHOOK_SECRET=
